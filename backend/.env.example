# ─── Trinetra FastAPI Backend — Environment Variables ───

# ── Actian/Edge Adapter (Actian-only storage runtime) ──
ACTIAN_MODE=edge
ACTIAN_LOCAL_DIR=./actian_local
ACTIAN_CLOUD_API_URL=
ACTIAN_API_KEY=

# ── Redis (Message Broker — replaces Kafka) ──
REDIS_URL=redis://localhost:6379

# ── CORS (Devraj's React Frontend) ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Server ──
HOST=0.0.0.0
PORT=8080

# ── Optional service auth for agent namespace PATCH ──
AGENT_SERVICE_TOKEN=

# ── Actian VectorAI (optional backend-side collection bootstrap) ──
VECTORAI_URL=localhost:50051
