### 5.4 Agent 4: GST Reconciliation Agent
**File:** [gst-agent/main.py](file:///Users/utkarshsingh/Desktop/Trinetra/agents/gst-agent/main.py)
**Current lines:** 170

#### What to add:
Embed the GST pattern and search historical fraud patterns.

```python
# Add to imports:
from shared.vectorai_client import VectorAIClient
vectorai = VectorAIClient()

# Add INSIDE process(), after computing results (before return):

# ── Actian VectorAI: Store GST pattern ──
gst_summary = (
    f"GST reconciliation: discrepancy={itc_result['discrepancy_pct']}%, "
    f"circular_trade_index={circular_result['circular_trade_index']}, "
    f"cycles={len(circular_result['suspicious_cycles'])}, "
    f"status={status}"
)
vectorai.upsert(
    collection="gst_patterns",
    doc_id=f"{application_id}_gst",
    text=gst_summary,
    metadata={
        "application_id": application_id,
        "agent": "gst-agent",
        "discrepancy_pct": itc_result["discrepancy_pct"],
        "circular_trade_index": circular_result["circular_trade_index"],
        "status": status,
    },
)

# ── Search for historically similar fraud patterns ──
if status in ("FLAG", "WARNING"):
    similar_fraud = vectorai.search(
        collection="gst_patterns",
        query_text=f"high GST discrepancy circular trading fraud {status}",
        top_k=5,
        min_score=0.65,
    )
    flagged_matches = [
        r for r in similar_fraud
        if r["metadata"].get("application_id") != application_id
        and r["metadata"].get("status") in ("FLAG", "WARNING")
    ]
    if flagged_matches:
        self.logger.warning(
            f"GST pattern matches {len(flagged_matches)} previously flagged applications",
            extra={"agent_name": self.AGENT_NAME, "application_id": application_id},
        )
