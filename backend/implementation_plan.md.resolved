### 5.7 Agent 7: Web Intelligence Agent ⭐ (HIGHEST IMPACT — Weaviate Replacement)
**File:** [web-agent/main.py](file:///Users/utkarshsingh/Desktop/Trinetra/agents/web-agent/main.py)  
**Current lines:** 280

#### What to change:
**This is the biggest change.** Replace ALL Weaviate `query_weaviate_collection()` calls with Actian VectorAI calls.

```python
# REMOVE these lines:
#   WEAVIATE_URL = os.getenv("WEAVIATE_URL", "http://weaviate:8080")
#   def query_weaviate_collection(...)

# ADD:
from shared.vectorai_client import VectorAIClient
vectorai = VectorAIClient()

# Replace query_weaviate_collection with:
def query_actian_collection(collection: str, query_text: str, top_k: int = 10, min_score: float = 0.75) -> list[dict]:
    """Query Actian VectorAI (replaces Weaviate). Uses cosine similarity."""
    results = vectorai.search(
        collection=collection,
        query_text=query_text,
        top_k=top_k,
        min_score=min_score,
    )
    return [r["metadata"] for r in results]

# Replace fetch_news():
def fetch_news(company_name: str, industry: str) -> list:
    hits = query_actian_collection(
        "news_articles",
        f"{company_name} {industry} risk scandal fraud",
        top_k=10, min_score=0.70,
    )
    scored_news = []
    for hit in hits:
        sentiment = score_article(hit.get("headline", ""), hit.get("body", ""))
        scored_news.append({
            "headline": hit.get("headline", ""),
            "source_url": hit.get("source_url", ""),
            "credibility_score": hit.get("credibility_score", 0),
            "sentiment_score": sentiment["sentiment_score"],
            "risk_contribution": sentiment["risk_contribution"],
            "published_at": hit.get("published_at", ""),
            "entity_tags": hit.get("entity_tags", []),
        })
    return scored_news

# Replace fetch_litigation() fallback section:
#   Instead of querying Weaviate LitigationRecord, query:
    hits = query_actian_collection("litigation_records", company_name, top_k=10, min_score=0.60)

# Replace fetch_regulatory_flags():
    hits = query_actian_collection("rbi_circulars", f"{industry} regulation risk", top_k=5, min_score=0.60)
```

