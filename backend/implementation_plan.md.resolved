### 5.6 Agent 6: MCA Intelligence Agent
**File:** [mca-agent/main.py](file:///Users/utkarshsingh/Desktop/Trinetra/agents/mca-agent/main.py)
**Current lines:** 233

#### What to change:
**Replace the `fetch_from_weaviate_fallback()` function entirely** to use Actian VectorAI instead of Weaviate.

```python
# Replace Weaviate import and URL with:
from shared.vectorai_client import VectorAIClient
vectorai = VectorAIClient()

# Replace fetch_from_weaviate_fallback() with:
def fetch_from_actian_vectorai(company_name: str) -> dict:
    """Query Actian VectorAI mca_filings collection (replaces Weaviate)."""
    results = vectorai.search(
        collection="mca_filings",
        query_text=f"{company_name} MCA filing company status",
        top_k=5,
        min_score=0.60,
    )
    if not results:
        return {
            "company_status": "UNKNOWN", "director_changes_last_2yr": [],
            "charges_registered": [], "new_charge_flag": False,
            "director_din_list": [], "last_agm_date": "", "defaulter_flag": False,
        }
    risk_flags = [r for r in results if r["metadata"].get("risk_flag")]
    return {
        "company_status": "ACTIVE" if not risk_flags else "FLAGGED",
        "director_changes_last_2yr": [],
        "charges_registered": [
            {"description": r["metadata"].get("description", ""), "filing_date": r["metadata"].get("filing_date", "")}
            for r in results if r["metadata"].get("filing_type") == "CHARGE"
        ],
        "new_charge_flag": any(r["metadata"].get("filing_type") == "CHARGE" for r in results),
        "director_din_list": [],
        "last_agm_date": "",
        "defaulter_flag": any(r["metadata"].get("risk_flag") for r in results),
    }

#  In process(), change:
#    return fetch_from_weaviate_fallback(company_name)
#  To:
#    return fetch_from_actian_vectorai(company_name)
```

