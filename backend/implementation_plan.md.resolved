```python
# Add to imports:
from shared.vectorai_client import VectorAIClient
vectorai = VectorAIClient()

# Add INSIDE process(), before return:

# ── Actian VectorAI: Store PAN profile ──
pan_text = f"PAN verification: {pan}, name={extracted.get('full_name')}, category={extracted.get('category')}, confidence={extracted.get('confidence')}"
vectorai.upsert(
    collection="pan_profiles",
    doc_id=f"{application_id}_pan",
    text=pan_text,
    metadata={
        "application_id": application_id,
        "agent": "pan-verification-agent",
        "pan": pan,
        "full_name": extracted.get("full_name", ""),
        "category": extracted.get("category", ""),
        "confidence": extracted.get("confidence", 0),
    },
)

# ── Cross-application PAN deduplication ──
prior_pans = vectorai.hybrid_search(
    collection="pan_profiles",
    query_text=f"PAN {pan}",
    filters={"pan": pan},
    top_k=5,
)
prior_apps = [
    r["metadata"]["application_id"]
    for r in prior_pans
    if r["metadata"].get("application_id") != application_id
]
if prior_apps:
    self.logger.warning(
        f"PAN {pan} already seen in {len(prior_apps)} other applications: {prior_apps[:3]}",
        extra={"agent_name": self.AGENT_NAME, "application_id": application_id},
    )
```

Add `"prior_applications_same_pan": prior_apps` to the return dict.

