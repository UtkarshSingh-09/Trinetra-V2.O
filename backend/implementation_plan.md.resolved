## 3. Shared VectorAI Client

### [NEW] `agents/shared/vectorai_client.py`

This is the **single most important new file**. Every agent imports this.

```python
"""
Trinetra × Actian VectorAI Client
Shared client for all 14 agents to store and query vector embeddings.
Replaces Weaviate entirely.
"""
import os
import json
import uuid
import requests
from datetime import datetime, timezone
from sentence_transformers import SentenceTransformer

from .logger import get_logger

logger = get_logger("vectorai-client")

VECTORAI_URL = os.getenv("VECTORAI_URL", "http://localhost:5480")
VECTORAI_API_KEY = os.getenv("VECTORAI_API_KEY", "")
EMBEDDING_MODEL = os.getenv("VECTORAI_EMBEDDING_MODEL", "all-MiniLM-L6-v2")
EMBEDDING_DIM = int(os.getenv("VECTORAI_EMBEDDING_DIM", "384"))

# Lazy-load the model (shared across all agents in same process)
_model = None

def _get_model():
    global _model
    if _model is None:
        _model = SentenceTransformer(EMBEDDING_MODEL)
    return _model


class VectorAIClient:
    """
    Client for Actian VectorAI DB.
    Provides: embed → upsert → search → hybrid_search
    """

    def __init__(self):
        self.base_url = VECTORAI_URL.rstrip("/")
        self.headers = {
            "Content-Type": "application/json",
            "Authorization": f"Bearer {VECTORAI_API_KEY}",
        }

    # ── Embedding ──

    def embed(self, text: str) -> list[float]:
        """Generate a 384-dimensional embedding using SentenceTransformer."""
        model = _get_model()
        return model.encode(text).tolist()

    def embed_batch(self, texts: list[str]) -> list[list[float]]:
        """Batch embed multiple texts."""
        model = _get_model()
        return model.encode(texts).tolist()

    # ── Collection Management ──

    def create_collection(self, name: str, metadata_schema: dict = None):
        """Create a vector collection if it doesn't exist."""
        payload = {
            "name": name,
            "dimension": EMBEDDING_DIM,
            "distance_metric": "cosine",
            "metadata_schema": metadata_schema or {},
        }
        try:
            resp = requests.post(
                f"{self.base_url}/api/v1/collections",
                headers=self.headers,
                json=payload,
                timeout=10,
            )
            if resp.status_code in (200, 201, 409):  # 409 = already exists
                return True
            resp.raise_for_status()
        except Exception as e:
            logger.error(f"Failed to create collection '{name}': {e}")
            return False

    # ── Upsert ──

    def upsert(self, collection: str, doc_id: str, text: str, metadata: dict = None):
        """Embed text and store in Actian VectorAI with metadata."""
        embedding = self.embed(text)
        return self.upsert_raw(collection, doc_id, embedding, metadata or {})

    def upsert_raw(self, collection: str, doc_id: str, embedding: list[float], metadata: dict):
        """Store a pre-computed embedding in Actian VectorAI."""
        payload = {
            "id": doc_id,
            "vector": embedding,
            "metadata": {
                **metadata,
                "indexed_at": datetime.now(timezone.utc).isoformat(),
            },
        }
        try:
            resp = requests.post(
                f"{self.base_url}/api/v1/collections/{collection}/documents",
                headers=self.headers,
                json=payload,
                timeout=10,
            )
            resp.raise_for_status()
            return True
        except Exception as e:
            logger.error(f"VectorAI upsert failed [{collection}/{doc_id}]: {e}")
            return False

    def upsert_batch(self, collection: str, documents: list[dict]):
        """
        Batch upsert multiple documents.
        Each document: {"id": str, "text": str, "metadata": dict}
        """
        texts = [d["text"] for d in documents]
        embeddings = self.embed_batch(texts)

        payload = {
            "documents": [
                {
                    "id": d["id"],
                    "vector": emb,
                    "metadata": {
                        **d.get("metadata", {}),
                        "indexed_at": datetime.now(timezone.utc).isoformat(),
                    },
                }
                for d, emb in zip(documents, embeddings)
            ]
        }
        try:
            resp = requests.post(
                f"{self.base_url}/api/v1/collections/{collection}/documents/batch",
                headers=self.headers,
                json=payload,
                timeout=30,
            )
            resp.raise_for_status()
            return True
        except Exception as e:
            logger.error(f"VectorAI batch upsert failed [{collection}]: {e}")
            return False

    # ── Search ──

    def search(self, collection: str, query_text: str, top_k: int = 5, min_score: float = 0.0) -> list[dict]:
        """
        Semantic vector search using cosine similarity in Actian VectorAI.
        
        Returns list of: {"id": str, "score": float, "metadata": dict}
        """
        query_embedding = self.embed(query_text)
        return self.search_raw(collection, query_embedding, top_k, min_score)

    def search_raw(self, collection: str, query_vector: list[float], top_k: int = 5, min_score: float = 0.0) -> list[dict]:
        """Search with a pre-computed query vector."""
        payload = {
            "vector": query_vector,
            "top_k": top_k,
            "min_score": min_score,
        }
        try:
            resp = requests.post(
                f"{self.base_url}/api/v1/collections/{collection}/search",
                headers=self.headers,
                json=payload,
                timeout=10,
            )
            resp.raise_for_status()
            results = resp.json().get("results", [])
            return results
        except Exception as e:
            logger.error(f"VectorAI search failed [{collection}]: {e}")
            return []

    def hybrid_search(self, collection: str, query_text: str, filters: dict, top_k: int = 5) -> list[dict]:
        """
        Actian's KILLER FEATURE: Vector similarity + SQL-style metadata filtering.
        
        Example filters: {"industry": "Manufacturing", "risk_band": "HIGH"}
        This combines semantic search with structured data queries — 
        something Weaviate does but Actian does natively with SQL.
        """
        query_embedding = self.embed(query_text)
        payload = {
            "vector": query_embedding,
            "top_k": top_k,
            "filters": filters,  # SQL-style WHERE clauses
        }
        try:
            resp = requests.post(
                f"{self.base_url}/api/v1/collections/{collection}/search",
                headers=self.headers,
                json=payload,
                timeout=10,
            )
            resp.raise_for_status()
            return resp.json().get("results", [])
        except Exception as e:
            logger.error(f"VectorAI hybrid search failed [{collection}]: {e}")
            return []
```

### [MODIFY] `agents/shared/__init__.py`

Add the new import:
