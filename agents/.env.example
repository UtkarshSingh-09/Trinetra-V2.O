# ─── Trinetra Agents Environment Template ───
# Copy to: agents/.env
# Never commit real keys.

# Groq API (PD Agent)
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# Surepass APIs (MCA/Web/PAN Agents)
SUREPASS_API_KEY=
SUREPASS_BASE_URL=https://kyc-api.surepass.io/api/v1
SUREPASS_TOKEN=

# Actian VectorAI (replaces Weaviate)
VECTORAI_URL=localhost:50051
VECTORAI_EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTORAI_EMBEDDING_DIM=384

# Backend + Broker
BACKEND_URL=http://localhost:8080
REDIS_URL=redis://localhost:6379
AGENT_SERVICE_TOKEN=

# Models + Speech
MODEL_DIR=./risk-agent/models
WHISPER_MODEL=base
