### [NEW] Backend endpoint: `GET /api/vectorai/search`

Add to `backend/main.py`:
```python
@app.get("/api/vectorai/search")
async def vectorai_search(q: str, collection: str = "news_articles", top_k: int = 5):
    """Let frontend query Actian VectorAI directly for demo purposes."""
    from agents_shared_vectorai import VectorAIClient  # import adapter
    client = VectorAIClient()
    results = client.search(collection=collection, query_text=q, top_k=top_k)
    return {"query": q, "collection": collection, "results": results}
```

### [NEW] Backend endpoint: `GET /api/vectorai/collections`
```python
@app.get("/api/vectorai/collections")
async def vectorai_collections():
    """Return stats for all 14 Actian VectorAI collections."""
    collections = [
        "document_chunks", "financial_profiles", "gst_patterns",
        "bank_recon_profiles", "news_articles", "litigation_records",
        "rbi_circulars", "mca_filings", "pan_profiles", "risk_decisions",
        "pd_transcripts", "stress_scenarios", "audit_events", "application_summaries",
    ]
    return {"collections": collections, "count": len(collections)}
```

### [NEW] Backend endpoint: `POST /api/vectorai/hybrid-search`
```python
@app.post("/api/vectorai/hybrid-search")
async def vectorai_hybrid_search(body: dict):
    """Hybrid search: vector + metadata filters."""
    client = VectorAIClient()
    results = client.hybrid_search(
        collection=body.get("collection", "news_articles"),
        query_text=body.get("query", ""),
        filters=body.get("filters", {}),
        top_k=body.get("top_k", 5),
    )
    return {"results": results}
```

